{
  "name": "patent-cliff",
  "version": "1.0.0",
  "description": "MCP tool for pharmaceutical patent expiration analysis — PTA/PTE calculations, Paragraph IV status, PTAB proceedings, and generic entry risk scoring",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "pipeline:orangebook": "bun pipeline/fetch-orangebook.ts",
    "pipeline:pta": "bun pipeline/fetch-pta.ts",
    "pipeline:pte": "bun pipeline/fetch-pte.ts",
    "pipeline:ptab": "bun pipeline/fetch-ptab.ts",
    "pipeline:all": "bun pipeline/fetch-orangebook.ts && bun pipeline/fetch-pta.ts && bun pipeline/fetch-pte.ts && bun pipeline/fetch-ptab.ts"
  },
  "dependencies": {
    "@ctxprotocol/sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.5.0"
  }
}
