# PatentCliff MCP — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the HTTP server listens on (default: 8000)
PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file (default: ./patent-cliff.db)
# Created automatically on first run. Populated by pipeline scripts.
DB_PATH=./patent-cliff.db

# ─── PTAB API ─────────────────────────────────────────────────────────────────

# Optional. Increases rate limit on the USPTO PTAB API.
# PTAB_API_KEY=

# ─── CTX Protocol ─────────────────────────────────────────────────────────────

# Required in production for CTX marketplace authentication.
# CTX_API_KEY=
