# PatentCliff MCP — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the HTTP server listens on (default: 8000)
PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file (default: ./patent-cliff.db)
# Created automatically on first run. Populated by pipeline scripts.
DB_PATH=./patent-cliff.db

# ─── Pipeline: PatEx bulk data files ─────────────────────────────────────────
# PTA and PTE data is sourced from USPTO bulk files stored locally on the server.
# These files require a CAPTCHA to download from data.uspto.gov (human-only).
#
# Initial setup — copy files to the server:
#   scp ~/Downloads/pta_summary.csv    user@vps-ip:/var/lib/dokploy/volumes/patent-cliff/patex/
#   scp ~/Downloads/pte_summary.csv    user@vps-ip:/var/lib/dokploy/volumes/patent-cliff/patex/
#   scp ~/Downloads/g_application.tsv  user@vps-ip:/var/lib/dokploy/volumes/patent-cliff/patex/
#
# When to update:
#   pta_summary.csv / pte_summary.csv — annually (ECOPAIR dataset, data.uspto.gov/bulkdata/datasets/ecopair)
#   g_application.tsv                 — quarterly (PVGPATDIS dataset, data.uspto.gov/bulkdata/datasets/pvgpatdis)
#
# Defaults below assume DB_PATH=/data/... (production). Override if paths differ.
DATA_DIR=/data
# PTA_SUMMARY_PATH=/data/patex/pta_summary.csv
# PTE_SUMMARY_PATH=/data/patex/pte_summary.csv
# G_APPLICATION_PATH=/data/patex/g_application.tsv
